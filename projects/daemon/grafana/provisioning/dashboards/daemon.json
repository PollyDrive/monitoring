{
  "title": "daemon — мониторинг",
  "uid": "daemon-overview",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "schemaVersion": 38,
  "tags": ["daemon", "telegram-bot"],
  "panels": [

    {
      "id": 1,
      "title": "── ЗДОРОВЬЕ СЕРВИСА ──",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": { "content": "## Здоровье сервиса", "mode": "markdown" }
    },

    {
      "id": 2,
      "title": "Ошибки (ERROR) за 5 мин",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 2, "w": 8, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"ERROR\" [5m])) by (compose_service)",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "Необработанные исключения (Unhandled exception in handler)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 2, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"Unhandled exception in handler\" [1h])",
          "legendFormat": "за час",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "title": "WARNING за час",
      "type": "stat",
      "gridPos": { "x": 12, "y": 2, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"WARNING\" [1h])",
          "legendFormat": "warnings",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "Последние ошибки",
      "type": "logs",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{project=\"daemon\"} |= \"ERROR\" | line_format \"{{.container}} | {{__line__}}\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 10,
      "title": "── ДАННЫЕ ──",
      "type": "text",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 2 },
      "options": { "content": "## Данные (PostgreSQL / Redis)", "mode": "markdown" }
    },

    {
      "id": 11,
      "title": "Ошибки PostgreSQL (asyncpg / agenda_service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({project=\"daemon\"} |~ \"Ошибка при .*(agenda|задач|пользовател|brain dump)\" [5m]))",
          "legendFormat": "DB ошибки",
          "refId": "A"
        },
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"asyncpg\" |= \"error\" [5m]))",
          "legendFormat": "asyncpg",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "title": "Google Calendar — ошибки",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"Failed to\" |= \"Google\" [5m]))",
          "legendFormat": "gcal failures",
          "refId": "A"
        },
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"Failed to refresh Google token\" [5m]))",
          "legendFormat": "token refresh",
          "refId": "B"
        }
      ]
    },

    {
      "id": 13,
      "title": "Просроченные задачи — разбор",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"Expired review: cancelled\" [24h])",
          "legendFormat": "отменено за сутки",
          "refId": "A"
        }
      ]
    },

    {
      "id": 14,
      "title": "Просроченные задачи — оставлены",
      "type": "stat",
      "gridPos": { "x": 6, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"Expired review: kept\" [24h])",
          "legendFormat": "оставлено за сутки",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "title": "── ВЗАИМОДЕЙСТВИЕ ──",
      "type": "text",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 2 },
      "options": { "content": "## Взаимодействие (LLM / агенда / планировщик)", "mode": "markdown" }
    },

    {
      "id": 21,
      "title": "LLM вызовы: успех vs fallback",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"Model fallback triggered\" [5m]))",
          "legendFormat": "fallback",
          "refId": "A"
        },
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"OpenCode request failed\" [5m]))",
          "legendFormat": "request failed",
          "refId": "B"
        },
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"Non-JSON output\" [5m]))",
          "legendFormat": "non-JSON response",
          "refId": "C"
        }
      ]
    },

    {
      "id": 22,
      "title": "Генерации агенды за сутки",
      "type": "stat",
      "gridPos": { "x": 12, "y": 34, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"agenda validation failed\" [24h])",
          "legendFormat": "validation failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },

    {
      "id": 23,
      "title": "Задачи отфильтрованы циклом",
      "type": "stat",
      "gridPos": { "x": 18, "y": 34, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |~ \"filtered out due to (cycle|sickness)\" [24h])",
          "legendFormat": "за сутки",
          "refId": "A"
        }
      ]
    },

    {
      "id": 24,
      "title": "LLM — ошибки по типу",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 42, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({project=\"daemon\"} |= \"simple_chat failed\" [24h]))",
          "legendFormat": "simple_chat",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({project=\"daemon\"} |= \"generate_day_summary failed\" [24h]))",
          "legendFormat": "day_summary",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({project=\"daemon\"} |= \"Morning message generation failed\" [24h]))",
          "legendFormat": "morning_message",
          "refId": "C"
        },
        {
          "expr": "sum(count_over_time({project=\"daemon\"} |= \"Rule suggestion failed\" [24h]))",
          "legendFormat": "rule_suggestion",
          "refId": "D"
        }
      ]
    },

    {
      "id": 25,
      "title": "Планировщик — последние события",
      "type": "logs",
      "gridPos": { "x": 12, "y": 42, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{project=\"daemon\"} |~ \"scheduler|morning_push|dump_reminder|weekly\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 30,
      "title": "── БЕЗОПАСНОСТЬ ──",
      "type": "text",
      "gridPos": { "x": 0, "y": 50, "w": 24, "h": 2 },
      "options": { "content": "## Безопасность", "mode": "markdown" }
    },

    {
      "id": 31,
      "title": "Prompt injection блоки",
      "type": "stat",
      "gridPos": { "x": 0, "y": 52, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"GuardrailViolation\" [24h])",
          "legendFormat": "за сутки",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },

    {
      "id": 32,
      "title": "Prompt injection — динамика",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 52, "w": 10, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"GuardrailViolation\" [1h]))",
          "legendFormat": "injection attempts",
          "refId": "A"
        },
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"Комментарий содержит недопустимые\" [1h]))",
          "legendFormat": "feedback blocked",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },

    {
      "id": 33,
      "title": "Лимит задач (temp_tasks cap)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 52, "w": 8, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"Достигнут лимит задач\" [24h])",
          "legendFormat": "за сутки",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "id": 40,
      "title": "Все логи (live)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 60, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{project=\"daemon\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }

  ]
}
