{
  "title": "daemon — мониторинг",
  "uid": "daemon-overview",
  "timezone": "browser",
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "schemaVersion": 38,
  "tags": ["daemon"],
  "panels": [

    {
      "id": 1,
      "title": "Ошибки (ERROR) за 5 мин",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({project=\"daemon\"} |= \"ERROR\" [5m])) by (compose_service)",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },

    {
      "id": 2,
      "title": "Unhandled exceptions (за 1 ч)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"Unhandled exception in handler\" [1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "WARNING за 1 ч",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"WARNING\" [1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "title": "Prompt injection (за 24 ч)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({project=\"daemon\"} |= \"GuardrailViolation\" [24h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "Последние ошибки",
      "type": "logs",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{project=\"daemon\"} |~ \"ERROR|WARNING|Traceback|Exception\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }

  ]
}
