{
  "uid": "lebowski-overview",
  "title": "Lebowski",
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [

    {
      "id": 1,
      "type": "timeseries",
      "title": "Ошибки (ERROR) за 5 мин",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (compose_service) (rate({project=\"lebowski\"} |= \"ERROR\" [5m]))",
          "legendFormat": "{{compose_service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Unhandled exceptions (за 1 ч)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({project=\"lebowski\"} |= \"Traceback\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [{ "type": "value", "options": { "0": { "text": "OK" } } }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "WARNING за 1 ч",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({project=\"lebowski\"} |= \"WARNING\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Доступ запрещён (за 1 ч)",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({project=\"lebowski\"} |= \"Доступ запрещён\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 5,
      "type": "logs",
      "title": "Последние ошибки",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{project=\"lebowski\"} |~ \"ERROR|WARNING|Traceback|Доступ запрещён\""
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true }
    }

  ]
}
